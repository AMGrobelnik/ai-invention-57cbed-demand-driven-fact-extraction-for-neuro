\newlabel{tab:mcnemar}{{1}{8}{McNemar's test results for pairwise accuracy comparisons}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces McNemar's test results (binomial exact, two-sided, $\alpha =0.05$) for pairwise accuracy comparisons. RFDE vs LINC: $p=0.50$ (not significant, $n_{10}=4$, $n_{01}=8$). RFDE vs CoT: $p=0.12$ (not significant, $n_{10}=6$, $n_{01}=14$). RFDE vs RAG: $p=0.0001$ (significant, $n_{10}=14$, $n_{01}=0$). Only RFDE vs RAG reaches statistical significance. Small discordant pair counts (4--14) indicate limited power to detect differences; the lack of significance vs LINC/CoT contradicts claims of architectural advantage.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:mcnemar}{{4}{9}{McNemar's test results (binomial exact, two-sided, $\alpha =0.05$) for pairwise accuracy comparisons. RFDE vs LINC: $p=0.50$ (not significant, $n_{10}=4$, $n_{01}=8$). RFDE vs CoT: $p=0.12$ (not significant, $n_{10}=6$, $n_{01}=14$). RFDE vs RAG: $p=0.0001$ (significant, $n_{10}=14$, $n_{01}=0$). Only RFDE vs RAG reaches statistical significance. Small discordant pair counts (4--14) indicate limited power to detect differences; the lack of significance vs LINC/CoT contradicts claims of architectural advantage}{figure.4}{}}
